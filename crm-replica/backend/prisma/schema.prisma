generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  tecnico
}

enum OrderStatus {
  presupuesto_generado
  oc_recibida
  facturado
  pago_recibido
  documentacion_enviada
  documentacion_aprobada
  service_programado
  en_ejecucion
  completado
  cancelado
}

enum Priority {
  baja
  media
  alta
}

enum EquipmentStatus {
  operativo
  mantenimiento
  fuera_servicio
  en_revision
}

enum DocumentEntityType {
  order
  client
  equipment
}

enum DocumentCategory {
  contract
  report
  photo
  other
}

enum EventEntityType {
  order
  client
  equipment
  document
  system
}

enum EventType {
  created
  updated
  deleted
  status_changed
  document_added
  document_removed
}

enum CalendarProvider {
  google
  outlook
}

enum CalendarSyncStatus {
  synced
  pending
  error
}

enum WarrantyStatus {
  unknown
  pending_review
  approved
  rejected
}

enum WarrantyCoverage {
  full
  partial
  none
}

enum WarrantySource {
  ticket
  order_override
}

enum MaintenanceFrequencyType {
  monthly
  quarterly
  semiannual
  annual
}

enum MaintenanceExecutionStatus {
  generated
  skipped
  failed
}

model Role {
  id    String   @id @default(cuid())
  name  UserRole @unique
  users User[]
}

model User {
  id             String                     @id @default(cuid())
  first_name     String
  last_name      String
  email          String                     @unique
  password       String
  phone          String?
  active         Boolean                    @default(true)
  password_reset_token   String?
  password_reset_expires DateTime?
  role_id        String
  role           Role                       @relation(fields: [role_id], references: [id])
  orders         ServiceOrderTechnician[]
  history        ServiceOrderStatusHistory[]
  location_events OrderLocationEvent[]
  calendar_connections ExternalCalendarConnection[]
  calendar_events      ExternalCalendarEvent[]
  technician_locations TechnicianLocation[]
  location_sharing     TechnicianLocationSharing?
  notifications  Notification[]
  created_at     DateTime                   @default(now())
  updated_at     DateTime                   @updatedAt
}

model Client {
  id                              String       @id @default(cuid())
  nombre_empresa                  String
  direccion                       String?
  telefono                        String?
  email                           String
  persona_contacto                String?
  fecha_vencimiento_documentacion DateTime?
  observaciones                   String?
  is_active                       Boolean      @default(true)
  deleted_at                      DateTime?
  equipments                      Equipment[]
  service_orders                  ServiceOrder[]
  maintenance_plans               MaintenancePlan[]
  portal_users                    PortalUser[]
  invoice_drafts                  InvoiceDraft[]
  tickets                         Ticket[]
  created_at                      DateTime     @default(now())
  updated_at                      DateTime     @updatedAt

  @@index([is_active, deleted_at])
}

model Ticket {
  id                  String        @id @default(cuid())
  client_id           String
  equipment_id        String?
  serial_number       String?
  channel             String
  issue_description   String
  priority            String
  category            String?
  status              String        @default("new")
  diagnosis           String?
  diagnosis_result    String?
  requires_intervention Boolean     @default(false)
  sla_response_deadline DateTime?
  sla_resolution_deadline DateTime?
  first_response_at   DateTime?
  resolved_at         DateTime?
  reported_by_name    String?
  reported_by_contact String?
  warranty_status     WarrantyStatus @default(unknown)
  coverage            WarrantyCoverage @default(none)
  approved_by         String?
  warranty_reason     String?
  warranty_notes      String?
  reviewed_at         DateTime?
  warranty_source     WarrantySource?
  deleted_at          DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  client              Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  events              TicketEvent[]
  service_orders      ServiceOrder[]

  @@index([client_id])
  @@index([status])
  @@index([deleted_at])
  @@index([status, created_at])
}

model TicketSLAConfig {
  id                    String   @id @default(cuid())
  client_id             String?
  priority              String
  response_time_hours   Int
  resolution_time_hours Int
  created_at            DateTime @default(now())

  @@index([priority, client_id, created_at])
}

model TicketEvent {
  id         String   @id @default(cuid())
  ticket_id  String
  type       String
  message    String?
  metadata   Json?
  created_at DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
}

model Equipment {
  id               String          @id @default(cuid())
  client_id        String
  client           Client          @relation(fields: [client_id], references: [id])
  tipo_equipo      String
  modelo           String?
  numero_serie     String          @unique
  ubicacion_planta String?
  observaciones    String?
  fecha_instalacion DateTime?
  estado_actual    EquipmentStatus @default(operativo)
  is_active        Boolean         @default(true)
  deleted_at       DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  @@index([client_id])
  @@index([is_active, deleted_at])
}

model ServiceOrder {
  id                       String                      @id @default(cuid())
  client_id                String
  equipment_id             String?
  maintenance_plan_id      String?
  ticket_id                String?
  client                   Client                      @relation(fields: [client_id], references: [id])
  equipment                Equipment?                  @relation(fields: [equipment_id], references: [id], onDelete: SetNull)
  maintenance_plan         MaintenancePlan?            @relation(fields: [maintenance_plan_id], references: [id], onDelete: SetNull)
  ticket                   Ticket?                     @relation(fields: [ticket_id], references: [id], onDelete: SetNull)
  estado                   String                      @default("presupuesto_generado")
  prioridad                Priority                    @default(media)
  prioridad_peso           Int                         @default(2)
  fecha_programada         DateTime?
  direccion_service        String?
  contacto_planta          String?
  telefono_contacto_planta String?
  observaciones            String?
  warranty_status          WarrantyStatus @default(unknown)
  coverage                 WarrantyCoverage @default(none)
  approved_by              String?
  warranty_reason          String?
  warranty_notes           String?
  reviewed_at              DateTime?
  warranty_source          WarrantySource?
  observaciones_cierre     String?
  tiempo_trabajado_horas   Float?
  firma_cliente            String?
  foto_trabajo_url         String?
  checklist_cierre         Json?
  is_active                Boolean                     @default(true)
  deleted_at               DateTime?
  technicians              ServiceOrderTechnician[]
  materials                OrderMaterial[]
  location_events          OrderLocationEvent[]
  external_calendar_events ExternalCalendarEvent[]
  invoice_draft            InvoiceDraft?
  status_history           ServiceOrderStatusHistory[]
  attachments              Attachment[]
  notifications            Notification[]
  created_at               DateTime                    @default(now())
  updated_at               DateTime                    @updatedAt

  @@index([fecha_programada])
  @@index([estado])
  @@index([client_id])
  @@index([ticket_id])
  @@index([equipment_id])
  @@index([maintenance_plan_id])
  @@index([is_active, deleted_at, estado, prioridad, fecha_programada])
}

model MaintenancePlan {
  id                String                   @id @default(cuid())
  client_id         String
  equipment_id      String
  name              String
  frequency_type    MaintenanceFrequencyType
  frequency_value   Int?
  last_executed_at  DateTime?
  next_execution_at DateTime
  is_active         Boolean                  @default(true)
  auto_generate     Boolean                  @default(true)
  client            Client                   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  equipment         Equipment                @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  orders            ServiceOrder[]
  executions        MaintenanceExecution[]
  created_at        DateTime                 @default(now())
  updated_at        DateTime                 @updatedAt

  @@index([is_active, next_execution_at])
  @@index([client_id])
  @@index([equipment_id])
}

model MaintenanceExecution {
  id          String                     @id @default(cuid())
  plan_id     String
  order_id    String?
  executed_at DateTime                   @default(now())
  status      MaintenanceExecutionStatus
  notes       String?
  plan        MaintenancePlan            @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  order       ServiceOrder?              @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([plan_id, executed_at])
}


model OrderStatusConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  color       String
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([is_active, sort_order])
}

model ExternalCalendarConnection {
  id                   String           @id @default(cuid())
  user_id              String
  provider             CalendarProvider
  access_token         String
  refresh_token        String?
  expires_at           DateTime?
  external_calendar_id String?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  user                 User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@index([provider, updated_at])
}

model ExternalCalendarEvent {
  id                String            @id @default(cuid())
  order_id          String
  user_id           String
  provider          CalendarProvider
  external_event_id String
  sync_status       CalendarSyncStatus @default(synced)
  last_error        String?
  last_synced_at    DateTime?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  order             ServiceOrder      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([order_id, user_id, provider])
  @@index([user_id, provider, sync_status])
}

model TechnicianLocation {
  id          String   @id @default(cuid())
  user_id     String
  lat         Float
  lng         Float
  accuracy    Float?
  captured_at DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, captured_at])
}

model TechnicianLocationSharing {
  id         String   @id @default(cuid())
  user_id    String   @unique
  enabled    Boolean  @default(false)
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model PortalUser {
  id            String   @id @default(cuid())
  client_id     String
  client        Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  email         String   @unique
  password      String
  active        Boolean  @default(true)
  last_login_at DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([client_id, active])
}

model ServiceOrderTechnician {
  id               String       @id @default(cuid())
  service_order_id String
  technician_id    String
  fecha_asignacion DateTime     @default(now())
  asignado_por     String?
  service_order    ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)
  technician       User         @relation(fields: [technician_id], references: [id], onDelete: Cascade)

  @@unique([service_order_id, technician_id])
  @@index([service_order_id])
  @@index([technician_id])
}


model OrderMaterial {
  id          String       @id @default(cuid())
  order_id    String
  order       ServiceOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  name        String
  quantity    Float
  unit_cost   Float        @default(0)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@index([order_id, created_at])
}

model OrderLocationEvent {
  id          String       @id @default(cuid())
  order_id    String
  user_id     String
  event_type  String
  latitude    Float
  longitude   Float
  created_at  DateTime     @default(now())
  order       ServiceOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([order_id, created_at])
  @@index([user_id, created_at])
}

model ServiceOrderStatusHistory {
  id               String       @id @default(cuid())
  service_order_id String
  estado_anterior  String?
  estado_nuevo     String
  campo_modificado String?
  valor_anterior   String?
  valor_nuevo      String?
  comentario       String?
  usuario_id       String
  created_at       DateTime     @default(now())
  service_order    ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)
  usuario          User         @relation(fields: [usuario_id], references: [id])

  @@index([service_order_id, created_at])
  @@index([campo_modificado])
}

model Notification {
  id               String        @id @default(cuid())
  user_id          String
  service_order_id String?
  client_id        String?
  kind             String?
  title            String
  description      String
  read             Boolean       @default(false)
  created_at       DateTime      @default(now())
  user             User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  service_order    ServiceOrder? @relation(fields: [service_order_id], references: [id], onDelete: SetNull)

  @@index([user_id, kind, service_order_id, created_at])
  @@index([user_id, kind, client_id, created_at])
  @@unique([user_id, kind, service_order_id])
}

model AutomationRule {
  id              String      @id @default(cuid())
  name            String
  active          Boolean     @default(true)
  trigger_type    String
  target_status   OrderStatus
  threshold_hours Int
  action_type     String
  action_payload  Json?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
}

model InvoiceDraft {
  id               String       @id @default(cuid())
  order_id         String       @unique
  client_id        String
  order            ServiceOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  client           Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  status           String       @default("draft")
  labor_hours      Float
  labor_rate       Float
  labor_amount     Float
  materials_amount Float
  total_amount     Float
  currency         String       @default("USD")
  payload          Json?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@index([client_id, created_at])
}

model Attachment {
  id               String       @id @default(cuid())
  service_order_id String
  file_name        String
  file_url         String
  mime_type        String?
  uploaded_by      String
  created_at       DateTime     @default(now())
  service_order    ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)

  @@index([service_order_id])
}

model Document {
  id          String             @id @default(cuid())
  entity_type DocumentEntityType
  entity_id   String
  file_name   String
  file_category DocumentCategory @default(other)
  file_path   String?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  @@index([entity_type, entity_id, created_at])
  @@index([created_at])
}

model EventLog {
  id            String          @id @default(cuid())
  entity_type   EventEntityType
  entity_id     String?
  event_type    EventType
  message       String
  actor_user_id String?
  created_at    DateTime        @default(now())

  @@index([entity_type, entity_id, created_at])
  @@index([created_at])
}

model SystemTaskRun {
  id          String   @id @default(cuid())
  task        String   @unique
  last_run_at DateTime
  updated_at  DateTime @updatedAt
}
